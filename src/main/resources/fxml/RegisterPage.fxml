<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.gui.panels.RegisterController"
           styleClass="outer-background">

    <VBox alignment="CENTER" maxWidth="460">

        <!-- White Card -->
        <VBox styleClass="register-card"
              spacing="12">

            <TextField fx:id="nameField"
                       promptText="Full Name"
                       styleClass="dark-input"/>

            <TextField fx:id="emailField"
                       promptText="Email Address"
                       styleClass="dark-input"/>

            <ComboBox fx:id="userTypeCombo"
                      promptText="User Type"
                      styleClass="dark-input"/>

            <TextField fx:id="departmentField"
                       promptText="Department ID"
                       styleClass="dark-input"/>

            <TextField
                    promptText="Student/Staff ID"
                       styleClass="dark-input"
                       fx:id="idNumberField"/>

            <PasswordField fx:id="passwordField"
                           promptText="Password"
                           styleClass="dark-input"/>

            <PasswordField fx:id="confirmPasswordField"
                           promptText="Confirm Password"
                           styleClass="dark-input"/>

            <Label text="Password must contain a combination of uppercase and lowercase letters, numbers, and special characters."
                   styleClass="hint-label"
                   wrapText="true"/>

            <Label fx:id="errorLabel"
                   styleClass="error-label"
                   text=""
                   wrapText="true"/>

            <!-- Buttons Row -->
            <HBox spacing="10" alignment="CENTER">
                <Button text="Cancel"
                        styleClass="cancel-button"
                        onAction="#handleCancel"/>
                <Button text="Sign Up"
                        styleClass="signup-button"
                        onAction="#handleRegister"/>
            </HBox>

        </VBox>
    </VBox>
</StackPane>